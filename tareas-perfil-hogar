<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
<title>My Nana — Planificador Inteligente</title>
<link href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,wght@0,300;0,400;0,500;0,600;1,400&family=Cormorant+Garamond:wght@400;500;600&display=swap" rel="stylesheet">
<style>
/* ═══════════════════════════════════════════
   TOKENS — igual al design system de My Nana
═══════════════════════════════════════════ */
:root{
  --g:#1A6B52;--g2:#0F4A38;--g3:#F0F7F4;--g4:#E1F0EB;
  --b:#D4A5A5;--b2:#BF9090;--b3:#F7EFEF;
  --cr:#F9F5F0;--txt:#1A2E25;--txt2:#4A6358;
  --r:14px;--shadow:0 4px 24px rgba(15,74,56,.10);
  --warn:#F5A623;--warn-bg:#FFF8EE;
}
*{box-sizing:border-box;margin:0;padding:0;-webkit-tap-highlight-color:transparent;}
html,body{min-height:100vh;scroll-behavior:smooth;}
body{font-family:'DM Sans',sans-serif;background:var(--cr);color:var(--txt);overflow-x:hidden;}

/* ── HEADER ── */
.app-header{background:var(--g2);padding:48px 24px 16px;position:sticky;top:0;z-index:50;}
@media(min-width:768px){.app-header{padding-top:16px;}}
.header-top{display:flex;align-items:center;justify-content:space-between;margin-bottom:12px;}
.header-logo{font-family:'Cormorant Garamond',serif;font-size:20px;color:#fff;}
.header-logo em{color:var(--b);font-style:normal;}
.header-nav{display:flex;align-items:center;gap:10px;}
.header-back{background:rgba(255,255,255,.1);border:none;color:rgba(255,255,255,.7);font-size:13px;padding:7px 14px;border-radius:99px;cursor:pointer;font-family:'DM Sans',sans-serif;text-decoration:none;display:inline-block;}
.progreso-wrap{background:rgba(255,255,255,.1);border-radius:99px;height:5px;overflow:hidden;}
.progreso-fill{height:100%;background:var(--b);border-radius:99px;transition:width .6s ease;}
.progreso-label{font-size:11px;color:rgba(255,255,255,.45);margin-top:5px;text-align:right;}

/* ── LAYOUT ── */
.layout{max-width:1160px;margin:0 auto;padding:24px 16px;}

/* ── PANEL ── */
.panel{background:#fff;border-radius:var(--r);border:1px solid var(--g4);overflow:hidden;margin-bottom:16px;}
.panel-header{background:var(--g2);padding:16px 20px;display:flex;align-items:center;justify-content:space-between;}
.panel-title{font-family:'Cormorant Garamond',serif;font-size:18px;color:#fff;}
.panel-sub{font-size:11px;color:rgba(255,255,255,.55);margin-top:2px;}
.panel-badge{background:var(--b);color:#fff;font-size:11px;font-weight:600;padding:3px 10px;border-radius:99px;}

/* ═══════════════════════════════════════════
   SETUP WIZARD (PERFIL DEL HOGAR)
═══════════════════════════════════════════ */
#wizardOverlay{
  position:fixed;inset:0;background:rgba(15,74,56,.85);z-index:200;
  display:flex;align-items:flex-end;justify-content:center;
  backdrop-filter:blur(4px);
}
#wizardOverlay.oculto{display:none;}
.wizard-sheet{
  background:#fff;border-radius:28px 28px 0 0;width:100%;max-width:560px;
  max-height:92vh;overflow-y:auto;padding:0 0 40px;
  animation:slideUp .38s cubic-bezier(.25,.46,.45,.94);
}
@media(min-width:640px){
  #wizardOverlay{align-items:center;}
  .wizard-sheet{border-radius:28px;max-height:88vh;}
}
@keyframes slideUp{from{transform:translateY(60px);opacity:0;}to{transform:translateY(0);opacity:1;}}

.wizard-header{
  background:var(--g2);padding:24px 24px 20px;position:sticky;top:0;z-index:5;
}
.wizard-title{font-family:'Cormorant Garamond',serif;font-size:22px;color:#fff;margin-bottom:4px;}
.wizard-sub{font-size:12px;color:rgba(255,255,255,.55);}
.wizard-steps{display:flex;gap:5px;margin-top:14px;}
.wstep{flex:1;height:3px;border-radius:99px;background:rgba(255,255,255,.2);transition:background .3s;}
.wstep.activo{background:var(--b);}
.wstep.hecho{background:rgba(255,255,255,.6);}

.wizard-body{padding:24px;}
.wizard-step{display:none;}
.wizard-step.activo{display:block;animation:fadeIn .25s ease;}
@keyframes fadeIn{from{opacity:0;transform:translateY(8px);}to{opacity:1;transform:translateY(0);}}

.wstep-title{font-family:'Cormorant Garamond',serif;font-size:20px;color:var(--txt);margin-bottom:4px;}
.wstep-desc{font-size:13px;color:var(--txt2);margin-bottom:20px;line-height:1.6;}

/* form inputs wizard */
.w-label{font-size:11px;font-weight:600;color:var(--txt2);text-transform:uppercase;letter-spacing:.04em;display:block;margin-bottom:5px;}
.w-input{width:100%;background:var(--cr);border:1.5px solid var(--g4);border-radius:10px;padding:11px 14px;font-family:'DM Sans',sans-serif;font-size:14px;color:var(--txt);outline:none;transition:all .2s;margin-bottom:14px;}
.w-input:focus{border-color:var(--g);background:#fff;box-shadow:0 0 0 3px rgba(26,107,82,.07);}
.w-select{width:100%;background:var(--cr);border:1.5px solid var(--g4);border-radius:10px;padding:11px 14px;font-family:'DM Sans',sans-serif;font-size:14px;color:var(--txt);outline:none;appearance:none;cursor:pointer;margin-bottom:14px;}
.w-select:focus{border-color:var(--g);}

/* counter widget */
.counter-grid{display:grid;grid-template-columns:1fr 1fr;gap:10px;margin-bottom:16px;}
.counter-item{background:var(--g3);border-radius:12px;padding:12px 14px;display:flex;align-items:center;justify-content:space-between;}
.counter-label{font-size:13px;font-weight:500;color:var(--txt);}
.counter-sub{font-size:11px;color:var(--txt2);}
.counter-ctrl{display:flex;align-items:center;gap:8px;}
.c-btn{width:30px;height:30px;border-radius:50%;border:1.5px solid var(--g4);background:#fff;font-size:16px;cursor:pointer;display:flex;align-items:center;justify-content:center;color:var(--g);transition:all .15s;line-height:1;}
.c-btn:hover{background:var(--g);color:#fff;border-color:var(--g);}
.c-val{font-size:17px;font-weight:600;color:var(--txt);min-width:20px;text-align:center;}

/* toggle chips */
.chip-grid{display:flex;flex-wrap:wrap;gap:8px;margin-bottom:16px;}
.chip{padding:8px 14px;border-radius:99px;border:1.5px solid var(--g4);background:#fff;font-size:13px;font-weight:500;color:var(--txt2);cursor:pointer;transition:all .18s;font-family:'DM Sans',sans-serif;}
.chip:hover{border-color:var(--g);color:var(--g);}
.chip.sel{background:var(--g);border-color:var(--g);color:#fff;}

/* horario table */
.horario-grid{display:grid;grid-template-columns:1fr 1fr;gap:10px;margin-bottom:16px;}
.horario-item{background:var(--cr);border-radius:10px;padding:12px;border:1px solid var(--g4);}
.horario-name{font-size:11px;font-weight:600;color:var(--txt2);text-transform:uppercase;letter-spacing:.04em;margin-bottom:6px;}
.horario-time{width:100%;border:none;background:transparent;font-family:'DM Sans',sans-serif;font-size:15px;font-weight:500;color:var(--txt);outline:none;cursor:pointer;}

/* wizard footer */
.wizard-footer{display:flex;gap:10px;padding:0 24px;margin-top:4px;}
.btn-next{flex:1;background:var(--g);color:#fff;border:none;border-radius:99px;padding:14px;font-size:14px;font-weight:500;font-family:'DM Sans',sans-serif;cursor:pointer;transition:all .2s;}
.btn-next:hover{background:var(--g2);}
.btn-back{background:var(--cr);color:var(--txt2);border:1.5px solid var(--g4);border-radius:99px;padding:14px 20px;font-size:14px;font-weight:500;font-family:'DM Sans',sans-serif;cursor:pointer;transition:all .2s;}
.btn-back:hover{background:var(--g3);}

/* ═══════════════════════════════════════════
   PERFIL RESUMEN — banner superior
═══════════════════════════════════════════ */
#perfilBanner{
  background:linear-gradient(135deg,var(--g2) 0%,#1a5540 100%);
  border-radius:var(--r);padding:20px;margin-bottom:20px;
  display:none;border:none;
}
#perfilBanner.visible{display:flex;align-items:center;gap:16px;flex-wrap:wrap;}
.perfil-avatar{
  width:54px;height:54px;border-radius:50%;background:var(--g);
  border:3px solid var(--b);display:flex;align-items:center;justify-content:center;
  font-size:24px;flex-shrink:0;
}
.perfil-info{flex:1;min-width:0;}
.perfil-nombre{font-family:'Cormorant Garamond',serif;font-size:20px;color:#fff;margin-bottom:2px;}
.perfil-desc{font-size:12px;color:rgba(255,255,255,.6);line-height:1.5;}
.perfil-chips{display:flex;flex-wrap:wrap;gap:5px;margin-top:8px;}
.perfil-chip{background:rgba(255,255,255,.12);color:rgba(255,255,255,.85);font-size:11px;padding:3px 10px;border-radius:99px;border:1px solid rgba(255,255,255,.15);}
.btn-editar-perfil{background:rgba(255,255,255,.1);color:rgba(255,255,255,.8);border:1px solid rgba(255,255,255,.2);border-radius:99px;padding:7px 14px;font-size:12px;font-family:'DM Sans',sans-serif;cursor:pointer;transition:all .2s;flex-shrink:0;}
.btn-editar-perfil:hover{background:rgba(255,255,255,.2);}

/* ═══════════════════════════════════════════
   BOTONES DE GENERACIÓN
═══════════════════════════════════════════ */
.gen-btns{display:grid;grid-template-columns:repeat(3,1fr);gap:10px;margin-bottom:20px;}
@media(max-width:480px){.gen-btns{grid-template-columns:1fr;}}
.gen-btn{
  background:#fff;border:1.5px solid var(--g4);border-radius:14px;
  padding:16px 12px;cursor:pointer;text-align:center;transition:all .22s;
  font-family:'DM Sans',sans-serif;position:relative;overflow:hidden;
}
.gen-btn::before{content:'';position:absolute;inset:0;background:var(--g);opacity:0;transition:opacity .2s;}
.gen-btn:hover::before{opacity:.04;}
.gen-btn:hover{border-color:var(--g);transform:translateY(-2px);box-shadow:0 6px 20px rgba(26,107,82,.12);}
.gen-btn:active{transform:translateY(0);}
.gen-btn.loading{pointer-events:none;opacity:.7;}
.gen-icon{font-size:26px;margin-bottom:6px;}
.gen-label{font-size:13px;font-weight:600;color:var(--txt);margin-bottom:2px;}
.gen-desc{font-size:11px;color:var(--txt2);line-height:1.4;}

/* ═══════════════════════════════════════════
   SEMANA CALENDARIO
═══════════════════════════════════════════ */
.semana-nav{display:flex;align-items:center;justify-content:space-between;margin-bottom:16px;}
.semana-titulo{font-family:'Cormorant Garamond',serif;font-size:20px;color:var(--txt);}
.semana-range{font-size:12px;color:var(--txt2);margin-top:1px;}
.btn-semana{background:var(--g3);border:1.5px solid var(--g4);border-radius:99px;padding:7px 14px;font-size:12px;font-weight:500;cursor:pointer;color:var(--g);font-family:'DM Sans',sans-serif;transition:all .15s;}
.btn-semana:hover{background:var(--g4);}

.dias-scroll{display:flex;gap:8px;overflow-x:auto;padding-bottom:4px;-ms-overflow-style:none;scrollbar-width:none;margin-bottom:16px;}
.dias-scroll::-webkit-scrollbar{display:none;}
.dia-tab{flex-shrink:0;width:72px;border-radius:12px;border:1.5px solid var(--g4);background:#fff;padding:10px 6px;text-align:center;cursor:pointer;transition:all .2s;font-family:'DM Sans',sans-serif;}
.dia-tab.activo{background:var(--g);border-color:var(--g);}
.dia-tab.hoy{border-color:var(--g);}
.dia-letra{font-size:10px;font-weight:600;letter-spacing:.04em;text-transform:uppercase;color:var(--txt2);}
.dia-num{font-size:18px;font-weight:600;color:var(--txt);margin-top:1px;}
.dia-dot{width:5px;height:5px;border-radius:50%;background:var(--b);margin:4px auto 0;}
.dia-tab.activo .dia-letra,.dia-tab.activo .dia-num{color:#fff;}
.dia-tab.activo .dia-dot{background:rgba(255,255,255,.6);}
.dia-tab.hoy:not(.activo) .dia-num{color:var(--g);}
.dia-count{font-size:9px;color:var(--txt2);margin-top:2px;}
.dia-tab.activo .dia-count{color:rgba(255,255,255,.7);}

/* tareas del día */
.dia-panel{display:none;}
.dia-panel.activo{display:block;}
.tarea-card{
  background:#fff;border-radius:14px;border:1px solid var(--g4);
  margin-bottom:10px;overflow:hidden;transition:all .2s;
  box-shadow:0 2px 8px rgba(0,0,0,.04);
}
.tarea-card.hecha{opacity:.65;}
.tarea-top{display:flex;align-items:center;gap:10px;padding:13px 14px;}
.tarea-emoji-wrap{width:40px;height:40px;border-radius:10px;display:flex;align-items:center;justify-content:center;font-size:20px;flex-shrink:0;}
.tarea-info{flex:1;min-width:0;}
.tarea-nombre{font-size:13px;font-weight:500;color:var(--txt);}
.tarea-nombre.hecha{text-decoration:line-through;color:#bbb;}
.tarea-meta{font-size:11px;color:var(--txt2);margin-top:3px;display:flex;align-items:center;gap:6px;flex-wrap:wrap;}
.cat-pill{font-size:10px;padding:2px 8px;border-radius:99px;font-weight:500;}
.prioridad-dot{width:6px;height:6px;border-radius:50%;}
.tarea-check{
  width:34px;height:34px;border-radius:50%;border:2.5px solid var(--g4);
  background:transparent;cursor:pointer;display:flex;align-items:center;justify-content:center;
  transition:all .2s;flex-shrink:0;
}
.tarea-check.done{background:var(--g);border-color:var(--g);}
.tarea-check .check-icon{font-size:15px;opacity:0;}
.tarea-check.done .check-icon{opacity:1;}

/* empty / loading state */
.empty-dia{text-align:center;padding:48px 20px;color:var(--txt2);}
.empty-dia-icon{font-size:44px;margin-bottom:12px;}
.empty-dia-title{font-size:15px;font-weight:500;color:var(--txt);margin-bottom:4px;}
.empty-dia-sub{font-size:13px;}

.loading-spinner{
  display:flex;flex-direction:column;align-items:center;justify-content:center;
  padding:56px 20px;gap:14px;
}
.spinner{
  width:42px;height:42px;border:3px solid var(--g4);border-top-color:var(--g);
  border-radius:50%;animation:spin .8s linear infinite;
}
@keyframes spin{to{transform:rotate(360deg);}}
.spinner-text{font-size:13px;color:var(--txt2);text-align:center;line-height:1.6;}

/* ═══════════════════════════════════════════
   PANEL LATERAL — resumen + perfil
═══════════════════════════════════════════ */
@media(min-width:860px){
  .grid-layout{display:grid;grid-template-columns:1fr 340px;gap:20px;align-items:start;}
}
.stat-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:8px;padding:16px;border-bottom:1px solid var(--g4);}
.stat-box{background:var(--g3);border-radius:10px;padding:12px 8px;text-align:center;}
.stat-num{font-family:'Cormorant Garamond',serif;font-size:28px;color:var(--g);}
.stat-lbl{font-size:11px;color:var(--txt2);}
.stat-box.rosa{background:var(--b3);}
.stat-box.rosa .stat-num{color:var(--b2);}

/* cat bars */
.cat-bars{padding:14px 16px;display:flex;flex-direction:column;gap:8px;}
.cat-row{display:flex;align-items:center;gap:8px;}
.cat-row-label{font-size:12px;color:var(--txt2);width:90px;flex-shrink:0;}
.cat-bar-wrap{flex:1;background:var(--g4);border-radius:99px;height:5px;overflow:hidden;}
.cat-bar-fill{height:100%;background:var(--g);border-radius:99px;transition:width .5s ease;}
.cat-row-count{font-size:11px;color:var(--g);font-weight:500;width:28px;text-align:right;}

/* prioridades cards */
.prio-section{padding:14px 16px;border-top:1px solid var(--g4);}
.prio-title{font-size:12px;font-weight:600;color:var(--txt);margin-bottom:10px;text-transform:uppercase;letter-spacing:.04em;}
.prio-list{display:flex;flex-direction:column;gap:6px;}
.prio-item{display:flex;align-items:center;gap:8px;background:var(--cr);border-radius:8px;padding:8px 10px;font-size:12px;color:var(--txt2);}
.prio-bullet{width:8px;height:8px;border-radius:50%;flex-shrink:0;}

/* ── TOAST ── */
.toast{position:fixed;top:80px;left:50%;transform:translateX(-50%) translateY(-80px);background:var(--g);color:#fff;font-size:13px;font-weight:500;padding:10px 20px;border-radius:99px;z-index:400;transition:transform .3s;white-space:nowrap;box-shadow:0 4px 16px rgba(26,107,82,.3);}
.toast.visible{transform:translateX(-50%) translateY(0);}

/* ── NO PERFIL state ── */
#noperfilState{text-align:center;padding:56px 24px;}
.np-icon{font-size:56px;margin-bottom:16px;}
.np-title{font-family:'Cormorant Garamond',serif;font-size:26px;color:var(--txt);margin-bottom:8px;}
.np-sub{font-size:14px;color:var(--txt2);line-height:1.7;max-width:340px;margin:0 auto 28px;}
.np-btn{background:var(--g);color:#fff;border:none;border-radius:99px;padding:15px 32px;font-size:15px;font-weight:500;cursor:pointer;font-family:'DM Sans',sans-serif;transition:all .2s;}
.np-btn:hover{background:var(--g2);transform:translateY(-2px);box-shadow:0 8px 24px rgba(26,107,82,.25);}

/* ─ Ajustes rápidos inline ─ */
.inline-badge{display:inline-block;background:var(--g3);color:var(--g);font-size:10px;font-weight:600;padding:2px 7px;border-radius:99px;margin-left:4px;border:1px solid var(--g4);}

/* Paso mascota */
.mascota-tipo{display:grid;grid-template-columns:repeat(4,1fr);gap:8px;margin-bottom:16px;}
.mascota-opt{
  border:1.5px solid var(--g4);border-radius:12px;background:#fff;
  padding:12px 6px;text-align:center;cursor:pointer;transition:all .18s;
}
.mascota-opt.sel{border-color:var(--g);background:var(--g3);}
.mascota-opt:hover{border-color:var(--g);}
.mascota-emoji{font-size:24px;margin-bottom:4px;}
.mascota-name{font-size:11px;font-weight:500;color:var(--txt2);}
.mascota-opt.sel .mascota-name{color:var(--g);}

/* highlight de insights */
.insight-card{
  background:linear-gradient(135deg,var(--g3) 0%,var(--b3) 100%);
  border:1px solid var(--g4);border-radius:12px;padding:14px 16px;
  margin-bottom:14px;
}
.insight-title{font-size:12px;font-weight:600;color:var(--g);margin-bottom:4px;display:flex;align-items:center;gap:5px;}
.insight-text{font-size:12px;color:var(--txt2);line-height:1.6;}
</style>
</head>
<body>

<!-- ═══ TOAST ═══ -->
<div class="toast" id="toast"></div>

<!-- ═══════════════════════════════════════════
     WIZARD — Perfil del Hogar (overlay)
═══════════════════════════════════════════ -->
<div id="wizardOverlay" class="oculto">
  <div class="wizard-sheet">

    <div class="wizard-header">
      <div class="wizard-title">Cuéntame sobre tu hogar 🏠</div>
      <div class="wizard-sub">Solo tomará 2 minutos · My Nana aprenderá tu rutina</div>
      <div class="wizard-steps" id="wstepsBar">
        <div class="wstep activo" id="ws0"></div>
        <div class="wstep" id="ws1"></div>
        <div class="wstep" id="ws2"></div>
        <div class="wstep" id="ws3"></div>
        <div class="wstep" id="ws4"></div>
      </div>
    </div>

    <div class="wizard-body">

      <!-- PASO 0 — Personas -->
      <div class="wizard-step activo" id="step0">
        <div class="wstep-title">¿Quiénes viven en casa? 👨‍👩‍👧</div>
        <div class="wstep-desc">Esto permite que My Nana calcule la carga de trabajo correcta.</div>

        <div class="counter-grid">
          <div class="counter-item">
            <div><div class="counter-label">Adultos</div><div class="counter-sub">Mayores de 18</div></div>
            <div class="counter-ctrl">
              <button class="c-btn" onclick="cambiarContador('adultos',-1)">−</button>
              <span class="c-val" id="vAdultos">2</span>
              <button class="c-btn" onclick="cambiarContador('adultos',1)">+</button>
            </div>
          </div>
          <div class="counter-item">
            <div><div class="counter-label">Niños</div><div class="counter-sub">Menores de 18</div></div>
            <div class="counter-ctrl">
              <button class="c-btn" onclick="cambiarContador('ninos',-1)">−</button>
              <span class="c-val" id="vNinos">0</span>
              <button class="c-btn" onclick="cambiarContador('ninos',1)">+</button>
            </div>
          </div>
        </div>

        <!-- edades niños (dinámicas) -->
        <div id="edadesNinos" style="display:none;">
          <label class="w-label">Edades aproximadas de los niños</label>
          <div class="chip-grid" id="edadesChips">
            <span class="chip" data-val="bebe" onclick="toggleChip(this)">👶 Bebé (&lt;2)</span>
            <span class="chip" data-val="infante" onclick="toggleChip(this)">🧸 Infante (2–5)</span>
            <span class="chip" data-val="escolar" onclick="toggleChip(this)">🎒 Escolar (6–12)</span>
            <span class="chip" data-val="adolescente" onclick="toggleChip(this)">🎮 Adolescente (13+)</span>
          </div>
        </div>

        <label class="w-label">¿Hay empleada del hogar / nana?</label>
        <div class="chip-grid">
          <span class="chip sel" data-grp="nana" data-val="si" onclick="toggleSingle(this,'nana')">✅ Sí, hay nana</span>
