<script>
/* ═══════════════════════════════════════════
   ESTADO GLOBAL
═══════════════════════════════════════════ */
let perfil = null;
let semanaActual = {};  // { "Lunes": [tareas], ... }
let semanaAnterior = {}; // copia de la última semana generada
let diaActivo = '';
let wizardPaso = 0;

const DIAS = ['Lunes','Martes','Miércoles','Jueves','Viernes','Sábado','Domingo'];

const contadores = { adultos:2, ninos:0, cuartos:3, banos:2, mascotas:1 };
const chipsActivos = new Set();
const singleSelects = {};   // { grp: valor }
let mascotasSeleccionadas = new Set();

/* ═══════════════════════════════════════════
   INIT
═══════════════════════════════════════════ */
document.addEventListener('DOMContentLoaded', () => {
  const guardado = localStorage.getItem('mynana_perfil_hogar');
  if (guardado) {
    try { perfil = JSON.parse(guardado); mostrarConPerfil(); }
    catch(e) { mostrarSinPerfil(); }
  } else {
    mostrarSinPerfil();
  }
  renderDias();
  iniciarFechas();
});

function mostrarSinPerfil() {
  document.getElementById('noperfilState').style.display = 'block';
  document.getElementById('mainArea').style.display = 'none';
  document.getElementById('perfilBanner').classList.remove('visible');
}

function mostrarConPerfil() {
  document.getElementById('noperfilState').style.display = 'none';
  document.getElementById('mainArea').style.display = 'block';
  document.getElementById('perfilBanner').classList.add('visible');
  actualizarBannerPerfil();
}

/* ═══════════════════════════════════════════
   BANNER PERFIL
═══════════════════════════════════════════ */
function actualizarBannerPerfil() {
  if (!perfil) return;
  const nombre = perfil.nombreHogar || 'Mi Hogar';
  document.getElementById('perfilNombre').textContent = nombre;
  
  const p = perfil;
  const partes = [];
  if (p.adultos) partes.push(`${p.adultos} adulto${p.adultos>1?'s':''}`);
  if (p.ninos > 0) partes.push(`${p.ninos} niño${p.ninos>1?'s':''}`);
  if (p.cuartos) partes.push(`${p.cuartos} cuartos`);
  if (p.mascotas && p.mascotas > 0) partes.push(`🐾 ${p.mascotas} mascota${p.mascotas>1?'s':''}`);
  document.getElementById('perfilDesc').textContent = partes.join(' · ') || 'Perfil del hogar';

  const chips = [];
  if (p.tipoResidencia) chips.push({ emoji: '🏠', label: p.tipoResidencia });
  if (p.banos) chips.push({ emoji: '🚿', label: `${p.banos} baño${p.banos>1?'s':''}` });
  if (p.hasBalcon) chips.push({ emoji: '🌿', label: 'Balcón' });
  if (p.hayNana !== 'no') chips.push({ emoji: '👩‍🍳', label: 'Con nana' });
  if (p.estilo) chips.push({ emoji: '📅', label: estiloLabel(p.estilo) });

  document.getElementById('perfilChips').innerHTML = chips.map(c =>
    `<span class="perfil-chip">${c.emoji} ${c.label}</span>`
  ).join('');

  // avatar emoji según tipo
  const avt = p.mascotas > 0 ? '🏡' : (p.ninos > 0 ? '👨‍👩‍👧' : '🏠');
  document.getElementById('perfilAvatar').textContent = avt;
}

function estiloLabel(e) {
  const m = { balanceada:'Balanceada', intensiva_inicio:'Intensa inicio', suave_inicio:'Suave inicio', fin_semana_libre:'Fin semana libre' };
  return m[e] || e;
}

/* ═══════════════════════════════════════════
   WIZARD — NAVEGACIÓN
═══════════════════════════════════════════ */
function abrirWizard() {
  wizardPaso = 0;
  document.getElementById('wizardOverlay').classList.remove('oculto');
  renderWizardStep();
  // Pre-llenar con perfil existente si lo hay
  if (perfil) precargarWizard();
}

function cerrarWizard() {
  document.getElementById('wizardOverlay').classList.add('oculto');
}

function wizardNext() {
  if (wizardPaso < 4) {
    wizardPaso++;
    renderWizardStep();
  } else {
    guardarPerfil();
  }
}

function wizardBack() {
  if (wizardPaso > 0) { wizardPaso--; renderWizardStep(); }
}

function renderWizardStep() {
  document.querySelectorAll('.wizard-step').forEach((s,i) => {
    s.classList.toggle('activo', i === wizardPaso);
  });
  // progress dots
  for (let i = 0; i < 5; i++) {
    const d = document.getElementById('ws'+i);
    if (!d) continue;
    d.className = 'wstep' + (i < wizardPaso ? ' hecho' : (i === wizardPaso ? ' activo' : ''));
  }
  document.getElementById('btnWizBack').style.display = wizardPaso === 0 ? 'none' : 'block';
  document.getElementById('btnWizNext').textContent = wizardPaso === 4 ? '✨ Guardar y planificar' : 'Continuar →';

  // mostrar control mascotas dinámicamente
  if (wizardPaso === 2) actualizarPanelMascotas();
  // mostrar edades niños
  if (wizardPaso === 0) actualizarEdadesNinos();
}

function precargarWizard() {
  if (!perfil) return;
  if (perfil.adultos) { contadores.adultos = perfil.adultos; document.getElementById('vAdultos').textContent = perfil.adultos; }
  if (perfil.ninos !== undefined) { contadores.ninos = perfil.ninos; document.getElementById('vNinos').textContent = perfil.ninos; }
  if (perfil.cuartos) { contadores.cuartos = perfil.cuartos; document.getElementById('vCuartos').textContent = perfil.cuartos; }
  if (perfil.banos) { contadores.banos = perfil.banos; document.getElementById('vBanos').textContent = perfil.banos; }
  if (perfil.nombreHogar) document.getElementById('inNombreHogar').value = perfil.nombreHogar;
  if (perfil.tipoResidencia) document.getElementById('inTipoRes').value = perfil.tipoResidencia;
  if (perfil.notas) document.getElementById('inNotas').value = perfil.notas;
  // horarios
  if (perfil.horarios) {
    const h = perfil.horarios;
    if (h.desayuno) document.getElementById('hDesayuno').value = h.desayuno;
    if (h.almuerzo) document.getElementById('hAlmuerzo').value = h.almuerzo;
    if (h.merienda) document.getElementById('hMerienda').value = h.merienda;
    if (h.cena) document.getElementById('hCena').value = h.cena;
    if (h.nanaLlegada) document.getElementById('hNanaLlegada').value = h.nanaLlegada;
    if (h.nanaSalida) document.getElementById('hNanaSalida').value = h.nanaSalida;
  }
}

/* ═══════════════════════════════════════════
   WIZARD — CONTROLES
═══════════════════════════════════════════ */
function cambiarContador(key, delta) {
  const min = key === 'adultos' ? 1 : 0;
  contadores[key] = Math.max(min, (contadores[key] || 0) + delta);
  const ids = { adultos:'vAdultos', ninos:'vNinos', cuartos:'vCuartos', banos:'vBanos', mascotas:'vMascotas' };
  const el = document.getElementById(ids[key]);
  if (el) el.textContent = contadores[key];
  if (key === 'ninos') actualizarEdadesNinos();
}

function actualizarEdadesNinos() {
  const show = contadores.ninos > 0;
  document.getElementById('edadesNinos').style.display = show ? 'block' : 'none';
}

function toggleChip(el) {
  el.classList.toggle('sel');
  const v = el.dataset.val;
  if (el.classList.contains('sel')) chipsActivos.add(v);
  else chipsActivos.delete(v);
  if (el.closest('#mascotaGrid') === null && el.closest('#mascotaGrid') !== null) actualizarPanelMascotas();
}

function toggleSingle(el, grp) {
  document.querySelectorAll(`[data-grp="${grp}"]`).forEach(c => c.classList.remove('sel'));
  el.classList.add('sel');
  singleSelects[grp] = el.dataset.val;
}

function toggleMascota(el) {
  el.classList.toggle('sel');
  const v = el.dataset.val;
  if (el.classList.contains('sel')) mascotasSeleccionadas.add(v);
  else mascotasSeleccionadas.delete(v);
  actualizarPanelMascotas();
}

function actualizarPanelMascotas() {
  const hasMascotas = mascotasSeleccionadas.size > 0;
  document.getElementById('mascotaCtrl').style.display = hasMascotas ? 'block' : 'none';
  document.getElementById('noMascotaMsg').style.display = hasMascotas ? 'none' : 'block';
}

/* ═══════════════════════════════════════════
   GUARDAR PERFIL
═══════════════════════════════════════════ */
function guardarPerfil() {
  // Recolectar chips de días de trabajo
  const diasTrabajo = [];
  document.querySelectorAll('#step3 .chip.sel[data-val]').forEach(c => {
    if (DIAS.includes(c.dataset.val)) diasTrabajo.push(c.dataset.val);
  });

  // Recolectar prioridades
  const prioridades = [];
  document.querySelectorAll('#priorChips .chip.sel').forEach(c => prioridades.push(c.dataset.val));

  // Recolectar edades niños
  const edadesNinos = [];
  document.querySelectorAll('#edadesChips .chip.sel').forEach(c => edadesNinos.push(c.dataset.val));

  // Espacios extra
  const espacios = [];
  document.querySelectorAll('#step1 .chip.sel').forEach(c => { if(c.dataset.val) espacios.push(c.dataset.val); });

  // Necesidades mascota
  const necesidadesMascota = [];
  document.querySelectorAll('#step2 .chip.sel').forEach(c => { if(c.dataset.val && !c.closest('#mascotaGrid')) necesidadesMascota.push(c.dataset.val); });

  perfil = {
    nombreHogar: document.getElementById('inNombreHogar').value || 'Mi Hogar',
    adultos: contadores.adultos,
    ninos: contadores.ninos,
    edadesNinos,
    hayNana: singleSelects['nana'] || 'si',
    cuartos: contadores.cuartos,
    banos: contadores.banos,
    tipoResidencia: document.getElementById('inTipoRes').value,
    espaciosExtra: espacios,
    hasBalcon: espacios.includes('balcon'),
    hasPatio: espacios.includes('patio'),
    mascotas: mascotasSeleccionadas.size > 0 ? contadores.mascotas : 0,
    tiposMascota: [...mascotasSeleccionadas],
    necesidadesMascota,
    horarios: {
      desayuno: document.getElementById('hDesayuno').value,
      almuerzo: document.getElementById('hAlmuerzo').value,
      merienda: document.getElementById('hMerienda').value,
      cena: document.getElementById('hCena').value,
      nanaLlegada: document.getElementById('hNanaLlegada').value,
      nanaSalida: document.getElementById('hNanaSalida').value,
    },
    diasTrabajo,
    prioridades,
    estilo: singleSelects['estilo'] || 'balanceada',
    notas: document.getElementById('inNotas').value,
    actualizadoEn: new Date().toISOString(),
  };

  localStorage.setItem('mynana_perfil_hogar', JSON.stringify(perfil));
  cerrarWizard();
  mostrarConPerfil();
  showToast('✅ Perfil del hogar guardado · Genera tu primer plan');
}

/* ═══════════════════════════════════════════
   FECHAS Y DÍAS
═══════════════════════════════════════════ */
function iniciarFechas() {
  const hoy = new Date();
  const lunes = getLunes(hoy);
  const domingo = new Date(lunes);
  domingo.setDate(lunes.getDate() + 6);
  document.getElementById('semanaRange').textContent =
    `${formatFecha(lunes)} al ${formatFecha(domingo)}`;
  diaActivo = DIAS[hoy.getDay() === 0 ? 6 : hoy.getDay() - 1];
}

function getLunes(d) {
  const r = new Date(d);
  const day = r.getDay();
  const diff = day === 0 ? -6 : 1 - day;
  r.setDate(r.getDate() + diff);
  return r;
}

function formatFecha(d) {
  return d.toLocaleDateString('es-PA', { day:'numeric', month:'short' });
}

function renderDias() {
  const hoy = new Date();
  const diahoy = DIAS[hoy.getDay() === 0 ? 6 : hoy.getDay() - 1];
  const lunes = getLunes(hoy);
  
  const scroll = document.getElementById('diasScroll');
  scroll.innerHTML = DIAS.map((dia, i) => {
    const fecha = new Date(lunes);
    fecha.setDate(lunes.getDate() + i);
    const cnt = (semanaActual[dia] || []).length;
    const esHoy = dia === diahoy;
    const esActivo = dia === diaActivo;
    return `<div class="dia-tab${esActivo?' activo':''}${esHoy&&!esActivo?' hoy':''}" onclick="seleccionarDia('${dia}',this)">
      <div class="dia-letra">${dia.slice(0,3)}</div>
      <div class="dia-num">${fecha.getDate()}</div>
      ${cnt>0?`<div class="dia-dot"></div><div class="dia-count">${cnt} t</div>`:'<div style="height:9px;"></div>'}
    </div>`;
  }).join('');
}

function seleccionarDia(dia, el) {
  diaActivo = dia;
  document.querySelectorAll('.dia-tab').forEach(t => t.classList.remove('activo'));
  el.classList.add('activo');
  renderTareasDelDia();
}

/* ═══════════════════════════════════════════
   RENDER TAREAS
═══════════════════════════════════════════ */
function renderTareasDelDia() {
  const tareas = semanaActual[diaActivo] || [];
  const cont = document.getElementById('tareasContent');
  
  if (!tareas.length) {
    cont.innerHTML = `<div class="empty-dia">
      <div class="empty-dia-icon">😴</div>
      <div class="empty-dia-title">Sin tareas para ${diaActivo}</div>
      <div class="empty-dia-sub">Día libre o no es día de trabajo</div>
    </div>`;
    return;
  }

  const urgentes = tareas.filter(t => t.prioridad === 'urgente' && t.estado !== 'hecha');
  const prioSection = document.getElementById('prioSection');
  if (urgentes.length > 0) {
    prioSection.style.display = 'block';
    document.getElementById('prioList').innerHTML = urgentes.slice(0,3).map(t =>
      `<div class="prio-item">
        <div class="prio-bullet" style="background:${t.prioridad==='urgente'?'#E05C5C':'var(--g)'}"></div>
        <span>${t.emoji||'📋'} ${t.nombre} · <span style="opacity:.7">${t.hora||''}</span></span>
      </div>`
    ).join('');
  } else { prioSection.style.display = 'none'; }

  cont.innerHTML = tareas.map((t, idx) => {
    const catColor = getCatColor(t.cat);
    const hecha = t.estado === 'hecha';
    return `<div class="tarea-card${hecha?' hecha':''}" id="tc-${diaActivo}-${idx}">
      <div class="tarea-top">
        <div class="tarea-emoji-wrap" style="background:${catColor.bg}">${t.emoji||catEmoji(t.cat)}</div>
        <div class="tarea-info">
          <div class="tarea-nombre${hecha?' hecha':''}">${t.nombre}</div>
          <div class="tarea-meta">
            <span class="cat-pill" style="background:${catColor.bg};color:${catColor.fg}">${t.cat||'General'}</span>
            ${t.hora?`<span>⏰ ${t.hora}</span>`:''}
            ${t.duracion?`<span>⏱ ${t.duracion}</span>`:''}
            ${t.prioridad==='urgente'?`<span style="color:#E05C5C;font-weight:600;">🔴 Urgente</span>`:''}
          </div>
        </div>
        <button class="tarea-check${hecha?' done':''}" onclick="toggleTarea('${diaActivo}',${idx})">
          <span class="check-icon">✓</span>
        </button>
      </div>
    </div>`;
  }).join('');
}

function getCatColor(cat) {
  const map = {
    'Cocina':     { bg:'#FEF3E2', fg:'#C17B1A' },
    'Limpieza':   { bg:'#E8F5E9', fg:'#2E7D32' },
    'Lavandería': { bg:'#E3F2FD', fg:'#1565C0' },
    'Niños':      { bg:'#FCE4EC', fg:'#C2185B' },
    'Mascotas':   { bg:'#FFF3E0', fg:'#E65100' },
    'Mercado':    { bg:'#F3E5F5', fg:'#6A1B9A' },
    'Plantas':    { bg:'#E8F5E9', fg:'#1B5E20' },
    'Organización':{ bg:'#ECEFF1', fg:'#37474F' },
  };
  return map[cat] || { bg:'var(--g3)', fg:'var(--g)' };
}

function catEmoji(cat) {
  const m = { Cocina:'🍳', Limpieza:'🧹', Lavandería:'👕', Niños:'🎒', Mascotas:'🐾', Mercado:'🛒', Plantas:'🌿', Organización:'📦' };
  return m[cat] || '📋';
}

function toggleTarea(dia, idx) {
  if (!semanaActual[dia] || !semanaActual[dia][idx]) return;
  const t = semanaActual[dia][idx];
  t.estado = t.estado === 'hecha' ? 'pendiente' : 'hecha';
  renderTareasDelDia();
  actualizarStats();
}

/* ═══════════════════════════════════════════
   STATS
═══════════════════════════════════════════ */
function actualizarStats() {
  const todasTareas = Object.values(semanaActual).flat();
  const total = todasTareas.length;
  const hechas = todasTareas.filter(t => t.estado === 'hecha').length;
  const pend = total - hechas;

  document.getElementById('sTotalTareas').textContent = total;
  document.getElementById('sPendientes').textContent = pend;
  document.getElementById('sHechas').textContent = hechas;
  document.getElementById('totalBadge').textContent = `${total} tareas`;
  document.getElementById('progresoFill').style.width = total ? Math.round(hechas/total*100)+'%' : '0%';
  document.getElementById('progresoLabel').textContent = total ? `${hechas} de ${total} completadas · ${Math.round(hechas/total*100)}%` : 'Planificador inteligente de tareas';

  // cat bars
  const cats = {};
  todasTareas.forEach(t => { cats[t.cat] = (cats[t.cat]||0)+1; });
  document.getElementById('catBars').innerHTML = Object.entries(cats).sort((a,b)=>b[1]-a[1]).map(([cat,n]) => {
    const hechasCat = todasTareas.filter(t => t.cat===cat && t.estado==='hecha').length;
    const pct = Math.round(hechasCat/n*100);
    return `<div class="cat-row">
      <div class="cat-row-label">${catEmoji(cat)} ${cat}</div>
      <div class="cat-bar-wrap"><div class="cat-bar-fill" style="width:${pct}%"></div></div>
      <div class="cat-row-count">${hechasCat}/${n}</div>
    </div>`;
  }).join('') || '<div style="font-size:12px;color:var(--txt2);text-align:center;">Sin datos aún</div>';

  document.getElementById('statsPanel').style.display = total > 0 ? 'block' : 'none';
}

/* ═══════════════════════════════════════════
   GENERAR SEMANA (Claude API)
═══════════════════════════════════════════ */
async function generarSemana(modo) {
  if (!perfil) { showToast('⚠️ Primero configura tu perfil del hogar'); abrirWizard(); return; }

  // UI loading
  document.getElementById('emptyState').style.display = 'none';
  document.getElementById('tareasContent').style.display = 'none';
  document.getElementById('loadingState').style.display = 'block';
  document.getElementById('insightCard').style.display = 'none';
  const msgs = {
    auto: 'My Nana está analizando tu hogar...\nGenerando plan personalizado ✨',
    rapida: 'Preparando una semana express...\nTareas simples y rápidas ⚡',
  };
  document.getElementById('spinnerText').innerHTML = (msgs[modo] || 'Generando...').replace('\n','<br>');

  const prompt = buildPrompt(modo);

  try {
    const resp = await fetch('https://api.anthropic.com/v1/messages', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        model: 'claude-sonnet-4-20250514',
        max_tokens: 4000,
        system: `Eres My Nana, el asistente de gestión del hogar más inteligente de Latinoamérica. Tu misión es generar planes semanales de tareas 100% personalizados según el perfil real de cada hogar panameño y latinoamericano. Respondes ÚNICAMENTE en JSON válido, sin texto extra, sin markdown.`,
        messages: [{ role: 'user', content: prompt }]
      })
    });

    const data = await resp.json();
    const raw = data.content?.map(c => c.text||'').join('');
    const clean = raw.replace(/```json|```/g,'').trim();
    const resultado = JSON.parse(clean);

    // Cargar en semanaActual
    semanaActual = {};
    semanaAnterior = {};
    DIAS.forEach(dia => {
      const tareas = resultado[dia] || resultado[dia.toLowerCase()] || [];
      semanaActual[dia] = tareas.map(t => ({ ...t, estado: 'pendiente', emoji: catEmoji(t.cat) }));
      semanaAnterior[dia] = [...semanaActual[dia]];
    });

    // Insight
    if (resultado.__insight) {
      document.getElementById('insightText').textContent = resultado.__insight;
      document.getElementById('insightCard').style.display = 'block';
    }

    document.getElementById('loadingState').style.display = 'none';
    document.getElementById('tareasContent').style.display = 'block';
    renderDias();
    renderTareasDelDia();
    actualizarStats();
    showToast('✨ Plan generado para tu hogar');

  } catch(e) {
    console.error(e);
    document.getElementById('loadingState').style.display = 'none';
    document.getElementById('emptyState').style.display = 'block';
    showToast('❌ Error generando plan. Intenta de nuevo.');
  }
}

function repetirSemana() {
  if (!Object.keys(semanaAnterior).length) {
    showToast('⚠️ Primero genera un plan con ✨ Auto-planificar');
    return;
  }
  semanaActual = {};
  DIAS.forEach(dia => {
    semanaActual[dia] = (semanaAnterior[dia]||[]).map(t => ({ ...t, estado: 'pendiente' }));
  });
  document.getElementById('tareasContent').style.display = 'block';
  document.getElementById('emptyState').style.display = 'none';
  renderDias();
  renderTareasDelDia();
  actualizarStats();
  showToast('🔄 Semana anterior copiada');
}

/* ═══════════════════════════════════════════
   CONSTRUIR PROMPT
═══════════════════════════════════════════ */
function buildPrompt(modo) {
  const p = perfil;
  const modoDesc = {
    auto: 'Plan completo y detallado, bien distribuido, con tareas específicas para este hogar',
    rapida: 'Solo tareas esenciales y rápidas (máx 2-3 por día), semana ligera para familia ocupada',
  };

  return `Genera un plan semanal de tareas personalizado para este hogar.

PERFIL DEL HOGAR:
- Nombre: ${p.nombreHogar}
- Personas: ${p.adultos} adulto(s), ${p.ninos} niño(s)${p.edadesNinos?.length?` (edades: ${p.edadesNinos.join(', ')})`:''} 
- Hay nana/empleada: ${p.hayNana !== 'no' ? 'Sí' : 'No'}
- Casa: ${p.tipoResidencia}, ${p.cuartos} cuartos, ${p.banos} baños
- Espacios extra: ${p.espaciosExtra?.join(', ') || 'ninguno'}
- Mascotas: ${p.mascotas > 0 ? `${p.mascotas} ${p.tiposMascota?.join('/')||'mascota(s)'}` : 'No tiene'}
${p.mascotas > 0 && p.necesidadesMascota?.length ? `- Necesidades mascota: ${p.necesidadesMascota.join(', ')}` : ''}
- Horarios: desayuno ${p.horarios?.desayuno}, almuerzo ${p.horarios?.almuerzo}, cena ${p.horarios?.cena}
- Nana: llega ${p.horarios?.nanaLlegada}, sale ${p.horarios?.nanaSalida}
- Días de trabajo de la nana: ${p.diasTrabajo?.join(', ')||'Lunes a Viernes'}
- Prioridades del hogar: ${p.prioridades?.join(', ')||'limpieza, cocina'}
- Estilo de semana: ${p.estilo}
${p.notas ? `- Notas especiales: ${p.notas}` : ''}

MODO DE GENERACIÓN: ${modoDesc[modo] || modoDesc.auto}

INSTRUCCIONES:
1. Genera tareas ESPECÍFICAS a ESTE hogar. No genéricas.
2. Programa tareas de cocina 30-60 min antes de cada comida.
3. Si hay mascotas, incluye tareas de cuidado diarias.
4. Si hay niños, adapta tareas de limpieza y organización.
5. Distribuye la carga según el estilo solicitado.
6. Solo incluye tareas en los días que trabaja la nana.
7. Usa categorías: Cocina, Limpieza, Lavandería, Niños, Mascotas, Mercado, Plantas, Organización.
8. Incluye duración estimada (ej: "45 min", "20 min").
9. Marca como urgente solo 1-2 tareas por semana.
10. Genera un insight corto y personal en __insight.

FORMATO DE RESPUESTA (JSON puro, sin markdown):
{
  "Lunes": [
    { "nombre": "Nombre específico de la tarea", "cat": "Cocina", "hora": "07:30", "duracion": "30 min", "prioridad": "normal", "nota": "detalle opcional" }
  ],
  "Martes": [...],
  "Miércoles": [...],
  "Jueves": [...],
  "Viernes": [...],
  "Sábado": [...],
  "Domingo": [],
  "__insight": "Mensaje personalizado de 1-2 oraciones para este hogar específico"
}`;
}

