name: Aviso de cobro dia 13

on:
  schedule:
    - cron: '0 14 * * *'  # Corre todos los dias a las 9am hora Panama (UTC-5)
  workflow_dispatch:       # Permite correrlo manualmente desde GitHub

jobs:
  check-trials:
    runs-on: ubuntu-latest

    steps:
      - name: Obtener codigo
        uses: actions/checkout@v4

      - name: Configurar Node.js
        uses: actions/setup-node@v4
        with:
          node-version: '20'

      - name: Instalar dependencias
        run: |
          cd scripts
          npm install firebase-admin node-fetch

      - name: Ejecutar revision de pruebas
        env:
          FIREBASE_SERVICE_ACCOUNT: ${{ secrets.FIREBASE_SERVICE_ACCOUNT }}
          RESEND_API_KEY: ${{ secrets.RESEND_API_KEY }}
        run: node scripts/check-trials.js
